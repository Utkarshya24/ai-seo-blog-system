# Database
DATABASE_URL="postgresql://user:password@localhost:5432/blog"

# Google Gemini API
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"

# Cron Jobs Security
CRON_SECRET="your-secret-key-here"
ADMIN_API_TOKEN="your-global-admin-token"
APP_ENCRYPTION_KEY="base64-32-byte-key"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: keyword + publishing velocity controls
KEYWORDS_PER_NICHE="4"
COMPARISON_KEYWORDS_PER_NICHE="2"
BLOG_GENERATION_BATCH_SIZE="8"
AUTO_PUBLISH_GENERATED_POSTS="true"
BLOG_GENERATION_SCHEDULE="0 2 * * *"
METRICS_UPDATE_SCHEDULE="0 6 * * *"
TECH_NEWS_SCHEDULE="0 */2 * * *"
CONTENT_REFRESH_SCHEDULE="30 6 * * 1"
CONTENT_REFRESH_BATCH_SIZE="4"
CONTENT_REFRESH_MIN_IMPRESSIONS="200"
CONTENT_REFRESH_MAX_CTR="2.5"
CONTENT_REFRESH_MIN_POSITION="14"
CONTENT_REFRESH_MIN_AGE_DAYS="14"
DEFAULT_TENANT_ID=""
DEFAULT_WEBSITE_ID=""

# Optional: Google Search Console sync
GSC_SITE_URL="sc-domain:example.com"
GOOGLE_SEARCH_CONSOLE_ACCESS_TOKEN=""
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI=""

# External publishing target (optional)
EXTERNAL_PUBLISH_WEBHOOK_URL="https://example.com/api/content-ingest"
EXTERNAL_PUBLISH_WEBHOOK_SECRET="your-webhook-secret-here"

# Public content API protection (optional)
CONTENT_API_KEY="your-content-api-key"

# Optional: SEMrush integration for external SEO visibility signals
SEMRUSH_API_KEY=""
SEMRUSH_DATABASE="us"
