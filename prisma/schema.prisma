// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  OWNER
  EDITOR
  VIEWER
}

enum ExperimentStatus {
  RUNNING
  COMPLETED
  CANCELLED
}

enum ExperimentVariant {
  A
  B
}

enum AiProvider {
  CHATGPT
  PERPLEXITY
  GEMINI
  CLAUDE
  OTHER
}

enum OutreachStatus {
  PROSPECT
  CONTACTED
  FOLLOW_UP
  NEGOTIATING
  LIVE
  REJECTED
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  websites  Website[]
  keywords  Keyword[]
  posts     Post[]
  seoMetrics SeoMetrics[]
  adminTokens AdminToken[]
}

model Website {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  domain     String
  baseUrl    String
  niche      String   @default("general")
  gscProperty String?
  gscRefreshTokenEnc String?
  gscConnectedAt DateTime?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  keywords   Keyword[]
  posts      Post[]
  seoMetrics SeoMetrics[]
  aiMentions AiVisibilityMention[]
  outreachOpportunities OutreachOpportunity[]

  @@index([tenantId])
  @@index([domain])
  @@unique([tenantId, domain])
}

model Keyword {
  id         String    @id @default(cuid())
  tenantId   String?
  websiteId  String?
  tenant     Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  website    Website?  @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  keyword    String
  niche      String    @default("general")
  difficulty Int       @default(0) // SEO difficulty score 0-100
  searchVolume Int     @default(0)
  generatedAt DateTime @default(now())
  updatedAt DateTime   @updatedAt
  
  posts Post[]

  @@index([keyword])
  @@index([niche])
  @@index([tenantId])
  @@index([websiteId])
  @@unique([keyword, websiteId])
}

model Post {
  id        String    @id @default(cuid())
  tenantId  String?
  websiteId String?
  tenant    Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  website   Website?  @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  keywordId String
  keyword   Keyword   @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  
  title     String
  slug      String   @unique
  content   String   @db.Text
  metaDescription String
  
  status    String   @default("draft") // draft, published, scheduled
  publishedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  seoMetrics SeoMetrics?
  serpExperiments SerpExperiment[]

  @@index([tenantId])
  @@index([websiteId])
  @@index([keywordId])
  @@index([slug])
  @@index([status])
}

model SerpExperiment {
  id                       String            @id @default(cuid())
  tenantId                 String?
  websiteId                String?
  postId                   String
  post                     Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  status                   ExperimentStatus  @default(RUNNING)
  variantATitle            String
  variantAMetaDescription  String
  variantBTitle            String
  variantBMetaDescription  String
  impressionsA             Int               @default(0)
  clicksA                  Int               @default(0)
  impressionsB             Int               @default(0)
  clicksB                  Int               @default(0)
  winner                   ExperimentVariant?
  startedAt                DateTime          @default(now())
  completedAt              DateTime?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  @@index([postId, status])
  @@index([tenantId, websiteId, status])
}

model AiVisibilityMention {
  id         String     @id @default(cuid())
  tenantId   String?
  websiteId  String?
  website    Website?   @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  provider   AiProvider
  query      String
  sourceUrl  String?
  citedUrl   String
  rank       Int?
  snippet    String?
  detectedAt DateTime   @default(now())
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([tenantId, websiteId, detectedAt])
  @@index([provider, detectedAt])
  @@index([query])
}

model OutreachOpportunity {
  id             String         @id @default(cuid())
  tenantId       String?
  websiteId      String?
  website        Website?       @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  targetDomain   String
  targetUrl      String?
  contactName    String?
  contactEmail   String?
  contactSocial  String?
  status         OutreachStatus @default(PROSPECT)
  relevanceScore Int            @default(0) // 0-100
  authorityScore Int            @default(0) // 0-100
  expectedLink   String?
  notes          String?
  lastContactedAt DateTime?
  nextFollowUpAt DateTime?
  wonAt          DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([tenantId, websiteId, status])
  @@index([targetDomain])
  @@index([nextFollowUpAt])
}

model SeoMetrics {
  id        String    @id @default(cuid())
  tenantId  String?
  websiteId String?
  tenant    Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  website   Website?  @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  postId    String    @unique
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  backlinks Int      @default(0)
  traffic   Int      @default(0)
  impressions Int    @default(0)
  clicks    Int      @default(0)
  ctr       Float    @default(0)
  ranking   Int      @default(0)
  position  Float    @default(0)
  source    String   @default("manual")
  
  fetchedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([websiteId])
  @@index([postId])
}

model AdminToken {
  id        String    @id @default(cuid())
  name      String
  tokenHash String    @unique
  lastFour  String
  role      AdminRole @default(OWNER)
  tenantId  String?
  tenant    Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId])
  @@index([isActive])
}
